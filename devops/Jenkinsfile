pipeline {
    agent any

    tools {
        maven 'Maven-3.9.6'
        jdk 'JDK-21'
    }

    environment {
        SONAR_HOST_URL = 'https://sonarcloud.io'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Backend Build & Unit Tests') {
            steps {
                dir('backend') {
                    sh 'mvn clean test'
                }
            }
        }

        stage('SonarCloud Static Code Analysis') {
            steps {
                dir('backend') {
                    sh 'mvn sonar:sonar -Dsonar.projectKey=journeymate-ai -Dsonar.organization=journeymate'
                }
            }
        }

        stage('Frontend Build') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Docker Image Build') {
            steps {
                sh 'docker compose -f devops/docker-compose.yml build'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'JourneyMate AI Pipeline completed successfully!'
        }
    }
}
